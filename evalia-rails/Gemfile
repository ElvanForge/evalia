source "https://rubygems.org"

ruby "3.2.2"

# Core Rails gems
gem "rails", "~> 7.0.8"
gem "pg", "~> 1.5"
gem "puma", "~> 6.0"

# Asset pipeline and frontend
gem "sprockets-rails"
gem "tailwindcss-rails", "~> 2.0"
gem "stimulus-rails"
gem "turbo-rails"
gem "jbuilder"

# Authentication and authorization
gem "bcrypt", "~> 3.1.7"
gem "devise"
gem "pundit"

# Document Generation
gem "docx", "~> 0.8.0"
gem "prawn" # For PDF generation
gem "prawn-table"

# XML/CSV Handling
gem "nokogiri"

# Job Processing and Background Jobs
gem "sidekiq", "~> 7.0"
gem "redis", "~> 5.0"

# Stripe payment processing
gem "stripe"

# HTTP client for API calls
gem "faraday"

# Performance monitoring
gem "rack-mini-profiler"
gem "memory_profiler"

# Development and testing gems
group :development, :test do
  gem "debug", platforms: %i[ mri mingw x64_mingw ]
  gem "rspec-rails"
  gem "factory_bot_rails"
  gem "faker"
end

group :development do
  gem "web-console"
  gem "annotate"
  gem "bullet"
  gem "brakeman"
  gem "rubocop", require: false
end

group :test do
  gem "capybara"
  gem "selenium-webdriver"
  gem "webdrivers"
  gem "simplecov", require: false
end