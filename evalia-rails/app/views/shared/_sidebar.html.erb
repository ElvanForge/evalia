<div class="w-64 bg-white shadow-md flex flex-col h-screen">
  <div class="p-4 border-b border-gray-200 flex justify-center">
    <div class="flex items-center space-x-2">
      <span class="text-2xl font-bold text-primary">Evalia</span>
    </div>
  </div>
  
  <nav class="flex-1 px-2 py-4 space-y-1 overflow-y-auto">
    <a href="<%= root_path %>" class="<%= current_page?(root_path) ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="home" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Dashboard
    </a>
    
    <a href="<%= courses_path %>" class="<%= controller_name == 'courses' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="book-open" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Classes
    </a>
    
    <a href="<%= students_path %>" class="<%= controller_name == 'students' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="users" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Students
    </a>
    
    <a href="<%= assignments_path %>" class="<%= controller_name == 'assignments' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="clipboard-list" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Assignments
    </a>
    
    <a href="<%= quizzes_path %>" class="<%= controller_name == 'quizzes' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="check-square" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Quizzes
    </a>
    
    <a href="<%= lesson_plans_path %>" class="<%= controller_name == 'lesson_plans' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="file-text" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Lesson Plans
    </a>
    
    <a href="<%= reports_path %>" class="<%= controller_name == 'reports' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="bar-chart-2" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Reports
    </a>
    
    <a href="<%= settings_path %>" class="<%= controller_name == 'settings' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
      <i data-lucide="settings" class="mr-3 h-5 w-5 flex-shrink-0"></i>
      Settings
    </a>
    
    <% if current_user&.admin? || current_user&.manager? %>
      <div class="pt-4 border-t border-gray-200 mt-4">
        <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Administration</p>
        
        <div class="mt-2 space-y-1">
          <% if current_user&.admin? %>
            <a href="<%= teachers_path %>" class="<%= controller_name == 'teachers' && action_name == 'index' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
              <i data-lucide="user-check" class="mr-3 h-5 w-5 flex-shrink-0"></i>
              Manage Teachers
            </a>
          <% end %>
          
          <% if current_user&.admin? || current_user&.manager? %>
            <a href="<%= schools_path %>" class="<%= controller_name == 'schools' ? 'bg-primary text-white' : 'text-gray-700 hover:bg-gray-100' %> group flex items-center px-4 py-2 text-sm font-medium rounded-md">
              <i data-lucide="building" class="mr-3 h-5 w-5 flex-shrink-0"></i>
              Manage Schools
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </nav>
  
  <div class="p-4 border-t border-gray-200">
    <div class="flex items-center space-x-3">
      <div class="flex-shrink-0 h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
        <%= current_user&.first_name&.first&.upcase %><%= current_user&.last_name&.first&.upcase %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate">
          <%= current_user&.full_name %>
        </p>
        <p class="text-xs text-gray-500 truncate">
          <%= current_user&.email %>
        </p>
      </div>
      <div class="flex-shrink-0">
        <%= link_to logout_path, method: :delete, title: "Logout", class: "text-gray-400 hover:text-gray-500" do %>
          <i data-lucide="log-out" class="h-5 w-5"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>