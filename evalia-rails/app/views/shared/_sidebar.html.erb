<div class="w-64 bg-white h-screen flex flex-col shadow-sm" x-data="{ collapsed: false }">
  <!-- Sidebar Header -->
  <div class="h-16 flex items-center justify-between px-4 border-b">
    <!-- Logo -->
    <div class="flex items-center">
      <img src="/logo.png" alt="Evalia" class="h-8 w-auto mr-2" />
      <span class="text-xl font-bold text-primary">Evalia</span>
    </div>
    
    <!-- Toggle Button -->
    <button type="button" @click="collapsed = !collapsed" class="p-1 rounded-md hover:bg-gray-100">
      <i data-lucide="menu" class="h-5 w-5 text-gray-500"></i>
    </button>
  </div>
  
  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto py-4 px-3" :class="collapsed ? 'hidden' : ''">
    <ul class="space-y-1">
      <!-- Dashboard -->
      <li>
        <a href="<%= root_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/dashboard') %> hover:bg-gray-100">
          <i data-lucide="home" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Dashboard</span>
        </a>
      </li>
      
      <!-- Classes -->
      <li>
        <a href="<%= courses_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/courses') %> hover:bg-gray-100">
          <i data-lucide="book-open" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Classes</span>
        </a>
      </li>
      
      <!-- Students -->
      <li>
        <a href="<%= students_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/students') %> hover:bg-gray-100">
          <i data-lucide="users" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Students</span>
        </a>
      </li>
      
      <!-- Assignments -->
      <li>
        <a href="<%= assignments_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/assignments') %> hover:bg-gray-100">
          <i data-lucide="file-text" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Assignments</span>
        </a>
      </li>
      
      <!-- Quizzes -->
      <li>
        <a href="<%= quizzes_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/quizzes') %> hover:bg-gray-100">
          <i data-lucide="check-square" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Quizzes</span>
        </a>
      </li>
      
      <!-- Lesson Plans -->
      <li>
        <a href="<%= lesson_plans_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/lesson_plans') %> hover:bg-gray-100">
          <i data-lucide="book" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Lesson Plans</span>
        </a>
      </li>
      
      <!-- Reports -->
      <li>
        <a href="<%= reports_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/reports') %> hover:bg-gray-100">
          <i data-lucide="bar-chart-2" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Reports</span>
        </a>
      </li>
      
      <% if current_user&.is_admin? %>
        <!-- Schools (Admin Only) -->
        <li>
          <a href="<%= schools_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/schools') %> hover:bg-gray-100">
            <i data-lucide="building" class="h-5 w-5 mr-3 text-gray-500"></i>
            <span>Schools</span>
          </a>
        </li>
      <% end %>
    </ul>
    
    <!-- Divider -->
    <div class="my-4 border-t border-gray-200"></div>
    
    <!-- Secondary Navigation -->
    <ul class="space-y-1">
      <!-- Settings -->
      <li>
        <a href="<%= settings_path %>" class="flex items-center px-3 py-2 text-sm rounded-md <%= active_class('/settings') %> hover:bg-gray-100">
          <i data-lucide="settings" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Settings</span>
        </a>
      </li>
      
      <!-- Help -->
      <li>
        <a href="#" class="flex items-center px-3 py-2 text-sm rounded-md hover:bg-gray-100">
          <i data-lucide="help-circle" class="h-5 w-5 mr-3 text-gray-500"></i>
          <span>Help & Support</span>
        </a>
      </li>
    </ul>
  </nav>
  
  <!-- User Menu (Hidden when sidebar is collapsed) -->
  <div class="px-3 py-3 border-t" :class="collapsed ? 'hidden' : ''">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <img src="<%= gravatar_url(current_user&.email || '', 32) %>" alt="Profile" class="h-8 w-8 rounded-full" />
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-700"><%= current_user&.full_name || 'User' %></p>
        <p class="text-xs text-gray-500"><%= current_user&.email || '' %></p>
      </div>
      <div class="ml-auto">
        <%= link_to logout_path, method: :delete, class: "text-gray-400 hover:text-gray-600" do %>
          <i data-lucide="log-out" class="h-5 w-5"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>