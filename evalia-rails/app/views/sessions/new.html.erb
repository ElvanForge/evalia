<div class="min-h-screen flex flex-col md:flex-row">
  <!-- Login Form -->
  <div class="w-full md:w-1/2 flex flex-col justify-center p-8 md:p-12 lg:p-20">
    <div class="mx-auto w-full max-w-sm">
      <!-- Logo -->
      <div class="mb-8 text-center">
        <img src="/logo.png" alt="Evalia" class="h-12 mx-auto" />
        <h1 class="mt-4 text-3xl font-bold text-primary">Evalia</h1>
        <p class="mt-2 text-gray-600">Student Grade Tracking System</p>
      </div>
      
      <!-- Flash Messages -->
      <% flash.each do |type, message| %>
        <div class="flash <%= flash_class(type) %> mb-4">
          <%= message %>
        </div>
      <% end %>
      
      <!-- Login Form -->
      <%= form_tag login_path, method: :post, class: "space-y-6" do %>
        <div class="form-group">
          <label for="username" class="form-label">Username</label>
          <input type="text" id="username" name="username" class="form-input" autofocus required />
        </div>
        
        <div class="form-group">
          <div class="flex items-center justify-between">
            <label for="password" class="form-label">Password</label>
            <a href="#" class="text-xs font-medium text-primary hover:text-primary/90">Forgot password?</a>
          </div>
          <input type="password" id="password" name="password" class="form-input" required />
        </div>
        
        <div class="flex items-center">
          <input type="checkbox" id="remember_me" name="remember_me" class="form-checkbox" />
          <label for="remember_me" class="ml-2 block text-sm text-gray-600">Remember me</label>
        </div>
        
        <button type="submit" class="btn btn-primary w-full py-2.5">
          Sign in
        </button>
      <% end %>
      
      <div class="mt-6 text-center text-sm text-gray-500">
        <p>Don't have an account? Please contact your school administrator.</p>
      </div>
    </div>
  </div>
  
  <!-- Hero Section -->
  <div class="w-full md:w-1/2 bg-primary hidden md:block">
    <div class="h-full flex flex-col justify-center p-8 md:p-12 lg:p-20 text-white">
      <h2 class="text-3xl font-bold mb-6">Streamline Your Classroom Management</h2>
      <div class="space-y-6">
        <div class="flex items-start">
          <div class="flex-shrink-0 rounded-full p-1.5 bg-white/10">
            <i data-lucide="chart-bar" class="h-5 w-5"></i>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-medium">Comprehensive Analytics</h3>
            <p class="mt-1 text-white/80">Gain insights into student performance with detailed analytics and reporting.</p>
          </div>
        </div>
        
        <div class="flex items-start">
          <div class="flex-shrink-0 rounded-full p-1.5 bg-white/10">
            <i data-lucide="check-square" class="h-5 w-5"></i>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-medium">Interactive Assessments</h3>
            <p class="mt-1 text-white/80">Create and administer engaging quizzes with automatic grading.</p>
          </div>
        </div>
        
        <div class="flex items-start">
          <div class="flex-shrink-0 rounded-full p-1.5 bg-white/10">
            <i data-lucide="book" class="h-5 w-5"></i>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-medium">Intelligent Lesson Planning</h3>
            <p class="mt-1 text-white/80">Create, organize, and export lesson plans with AI-powered assistance.</p>
          </div>
        </div>
      </div>
      
      <blockquote class="mt-12 border-l-4 border-white/30 pl-4 italic">
        <p>"Evalia has transformed how I manage my classroom. I can't imagine teaching without it now!"</p>
        <footer class="mt-2 text-white/70">- Sarah Johnson, Mathematics Teacher</footer>
      </blockquote>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    lucide.createIcons();
  });
</script>