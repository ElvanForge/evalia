<!DOCTYPE html>
<html>
  <head>
    <title>Evalia - Grade Tracking System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-background">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-64 bg-white shadow-lg flex-shrink-0 z-10 overflow-y-auto">
        <%= render "shared/sidebar" %>
      </aside>
      
      <!-- Main content -->
      <main class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <header class="bg-primary text-white p-4 shadow-md flex-shrink-0 z-10">
          <div class="flex justify-between items-center">
            <h1 class="text-2xl font-bold">Evalia</h1>
            <div class="flex items-center space-x-4">
              <%= render "shared/user_menu" %>
            </div>
          </div>
        </header>
        
        <!-- Flash messages -->
        <% if notice %>
          <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4" role="alert">
            <%= notice %>
          </div>
        <% end %>
        
        <% if alert %>
          <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4" role="alert">
            <%= alert %>
          </div>
        <% end %>
        
        <!-- Main content scrollable area -->
        <div class="flex-1 overflow-auto p-6">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>