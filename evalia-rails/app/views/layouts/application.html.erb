<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:page_title) ? "#{yield(:page_title)} | Evalia" : "Evalia" %></title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">
  
  <!-- Tailwind CSS -->
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  
  <!-- Font -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Alpine.js (for simple interactions) -->
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  
  <!-- Application JavaScript -->
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  
  <!-- Additional Styles -->
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #ede8dd;
    }
    
    /* Card styles */
    .card {
      @apply bg-white rounded-lg shadow-sm overflow-hidden;
    }
    
    .card-header {
      @apply bg-primary text-white px-6 py-4 flex items-center;
    }
    
    .card-body {
      @apply p-6;
    }
    
    /* Button styles */
    .btn {
      @apply inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background;
    }
    
    .btn-primary {
      @apply bg-primary text-white hover:bg-primary/90;
    }
    
    .btn-secondary {
      @apply bg-secondary text-white hover:bg-secondary/90;
    }
    
    .btn-outline {
      @apply border border-input bg-background hover:bg-accent hover:text-accent-foreground;
    }
    
    /* Form styles */
    .form-group {
      @apply mb-4;
    }
    
    .form-label {
      @apply block text-sm font-medium text-gray-700 mb-1;
    }
    
    .form-input, .form-select, .form-textarea {
      @apply block w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50;
    }
    
    .form-checkbox, .form-radio {
      @apply rounded border-gray-300 text-primary focus:ring-primary;
    }
    
    /* Progress bar */
    .progress {
      @apply h-2 w-full bg-gray-200 rounded-full overflow-hidden;
    }
    
    .progress-bar {
      @apply h-full;
    }
    
    /* Pagination */
    .pagination {
      @apply flex justify-center space-x-1 mt-4;
    }
    
    .pagination a, .pagination span {
      @apply px-3 py-1 rounded hover:bg-gray-100;
    }
    
    .pagination em {
      @apply px-3 py-1 rounded bg-primary text-white font-normal;
    }
    
    /* Flash messages */
    .flash {
      @apply p-4 mb-4 rounded-md;
    }
    
    .flash-success {
      @apply bg-green-100 text-green-800;
    }
    
    .flash-error {
      @apply bg-red-100 text-red-800;
    }
    
    .flash-info {
      @apply bg-blue-100 text-blue-800;
    }
  </style>
</head>

<body>
  <% if logged_in? %>
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <%= render 'shared/sidebar' %>
      
      <!-- Main Content -->
      <div class="flex-1 flex flex-col">
        <!-- Top Bar -->
        <%= render 'shared/topbar' %>
        
        <!-- Page Content -->
        <main class="flex-1 overflow-auto p-6">
          <!-- Flash Messages -->
          <% flash.each do |type, message| %>
            <div class="flash <%= flash_class(type) %>">
              <%= message %>
            </div>
          <% end %>
          
          <!-- Breadcrumbs (if provided) -->
          <% if content_for?(:breadcrumbs) %>
            <div class="flex items-center text-sm text-gray-500 mb-4">
              <a href="/" class="hover:text-gray-700">Dashboard</a>
              <i data-lucide="chevron-right" class="h-4 w-4 mx-1"></i>
              <%= yield(:breadcrumbs) %>
            </div>
          <% end %>
          
          <!-- Page Content -->
          <%= yield %>
        </main>
      </div>
    </div>
  <% else %>
    <!-- Guest layout (for login and public pages) -->
    <div class="min-h-screen">
      <%= yield %>
    </div>
  <% end %>
  
  <!-- Initialize Lucide Icons -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });
  </script>
</body>
</html>