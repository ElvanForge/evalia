<% content_for :page_title do %>
  Classes
<% end %>

<div class="mb-6 flex justify-between items-center">
  <h1 class="text-2xl font-semibold">Your Classes</h1>
  
  <a href="<%= new_course_path %>" class="btn btn-primary">
    <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
    Add New Class
  </a>
</div>

<% if @courses.any? %>
  <!-- Classes Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @courses.each do |course| %>
      <div class="card hover:shadow-md transition-shadow">
        <div class="card-header">
          <h2 class="text-lg font-medium truncate flex-1"><%= course.name %></h2>
          
          <div class="flex">
            <a href="<%= edit_course_path(course) %>" class="text-white hover:text-gray-200 ml-2" title="Edit Class">
              <i data-lucide="edit" class="h-4 w-4"></i>
            </a>
            
            <%= button_to course_path(course), method: :delete, data: { confirm: "Are you sure you want to delete this class?" }, 
                         class: "text-white hover:text-gray-200 ml-2", title: "Delete Class" do %>
              <i data-lucide="trash-2" class="h-4 w-4"></i>
            <% end %>
          </div>
        </div>
        
        <div class="card-body">
          <div class="mb-4">
            <% if course.subject.present? || course.grade_level.present? %>
              <div class="text-sm text-gray-500 mb-2">
                <% if course.subject.present? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                    <%= course.subject %>
                  </span>
                <% end %>
                
                <% if course.grade_level.present? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    Grade <%= course.grade_level %>
                  </span>
                <% end %>
              </div>
            <% end %>
            
            <% if course.description.present? %>
              <p class="text-sm text-gray-600 line-clamp-2"><%= course.description %></p>
            <% end %>
          </div>
          
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <div class="flex items-center">
              <i data-lucide="user" class="h-4 w-4 mr-1 text-gray-400"></i>
              <span><%= course.students.count %> Students</span>
            </div>
            
            <div class="flex items-center">
              <i data-lucide="file-text" class="h-4 w-4 mr-1 text-gray-400"></i>
              <span><%= course.assignments.count %> Assignments</span>
            </div>
          </div>
          
          <% if course.period.present? || course.room.present? %>
            <div class="flex items-center text-xs text-gray-500 mb-4">
              <% if course.period.present? %>
                <div class="flex items-center mr-4">
                  <i data-lucide="clock" class="h-3 w-3 mr-1 text-gray-400"></i>
                  <span>Period <%= course.period %></span>
                </div>
              <% end %>
              
              <% if course.room.present? %>
                <div class="flex items-center">
                  <i data-lucide="home" class="h-3 w-3 mr-1 text-gray-400"></i>
                  <span>Room <%= course.room %></span>
                </div>
              <% end %>
            </div>
          <% end %>
          
          <a href="<%= course_path(course) %>" class="btn w-full">
            View Class
          </a>
        </div>
      </div>
    <% end %>
  </div>
  
  <!-- Pagination -->
  <div class="mt-6">
    <%= will_paginate @courses, class: "pagination" %>
  </div>
<% else %>
  <!-- Empty State -->
  <div class="bg-white rounded-lg shadow p-8 text-center">
    <div class="text-gray-400 mb-4">
      <i data-lucide="book-open" class="h-12 w-12 mx-auto"></i>
    </div>
    
    <h3 class="text-lg font-medium text-gray-900 mb-2">No Classes Yet</h3>
    <p class="text-gray-500 mb-6">Get started by creating your first class</p>
    
    <a href="<%= new_course_path %>" class="btn btn-primary">
      <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
      Add Class
    </a>
  </div>
<% end %>