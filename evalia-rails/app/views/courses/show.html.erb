<% content_for :page_title do %>
  <%= @course.name %>
<% end %>

<% content_for :breadcrumbs do %>
  <a href="<%= courses_path %>" class="hover:text-gray-700">Classes</a>
  <i data-lucide="chevron-right" class="h-4 w-4 mx-1"></i>
  <span class="font-medium"><%= @course.name %></span>
<% end %>

<!-- Header Information -->
<div class="bg-white rounded-lg shadow-sm overflow-hidden mb-6">
  <div class="bg-primary text-white p-6">
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-2xl font-bold mb-2"><%= @course.name %></h1>
        
        <div class="flex flex-wrap items-center text-sm opacity-90 space-x-3">
          <% if @course.subject.present? %>
            <div class="flex items-center">
              <i data-lucide="book" class="h-4 w-4 mr-1"></i>
              <span><%= @course.subject %></span>
            </div>
          <% end %>
          
          <% if @course.grade_level.present? %>
            <div class="flex items-center">
              <i data-lucide="graduation-cap" class="h-4 w-4 mr-1"></i>
              <span>Grade <%= @course.grade_level %></span>
            </div>
          <% end %>
          
          <% if @course.period.present? %>
            <div class="flex items-center">
              <i data-lucide="clock" class="h-4 w-4 mr-1"></i>
              <span>Period <%= @course.period %></span>
            </div>
          <% end %>
          
          <% if @course.room.present? %>
            <div class="flex items-center">
              <i data-lucide="home" class="h-4 w-4 mr-1"></i>
              <span>Room <%= @course.room %></span>
            </div>
          <% end %>
        </div>
      </div>
      
      <div class="flex space-x-2">
        <a href="<%= edit_course_path(@course) %>" class="inline-flex items-center justify-center rounded-md bg-white/10 hover:bg-white/20 px-3 py-2 text-sm font-medium text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-white">
          <i data-lucide="edit" class="h-4 w-4 mr-2"></i>
          Edit
        </a>
        
        <%= button_to course_path(@course), method: :delete, data: { confirm: "Are you sure you want to delete this class?" }, 
                     class: "inline-flex items-center justify-center rounded-md bg-white/10 hover:bg-white/20 px-3 py-2 text-sm font-medium text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-white" do %>
          <i data-lucide="trash-2" class="h-4 w-4 mr-2"></i>
          Delete
        <% end %>
      </div>
    </div>
    
    <% if @course.description.present? %>
      <div class="mt-4 text-sm bg-white/10 rounded-md p-3">
        <%= @course.description %>
      </div>
    <% end %>
  </div>
  
  <div class="px-6 py-4 flex items-center justify-between bg-gradient-to-r from-primary/10 to-primary/5">
    <div class="flex space-x-6">
      <div>
        <p class="text-sm text-gray-500 font-medium">Students</p>
        <p class="text-xl font-bold"><%= @course.students.count %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500 font-medium">Assignments</p>
        <p class="text-xl font-bold"><%= @course.assignments.count %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500 font-medium">At Risk</p>
        <p class="text-xl font-bold text-orange-600"><%= @at_risk_count %></p>
      </div>
    </div>
    
    <div class="flex space-x-2">
      <a href="<%= students_course_path(@course) %>" class="btn flex items-center space-x-1">
        <i data-lucide="users" class="h-4 w-4"></i>
        <span>Students</span>
      </a>
      
      <a href="<%= assignments_course_path(@course) %>" class="btn flex items-center space-x-1">
        <i data-lucide="file-text" class="h-4 w-4"></i>
        <span>Assignments</span>
      </a>
      
      <a href="<%= quizzes_course_path(@course) %>" class="btn flex items-center space-x-1">
        <i data-lucide="check-square" class="h-4 w-4"></i>
        <span>Quizzes</span>
      </a>
      
      <a href="<%= reports_course_path(@course) %>" class="btn flex items-center space-x-1">
        <i data-lucide="bar-chart-2" class="h-4 w-4"></i>
        <span>Reports</span>
      </a>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <!-- Students Card -->
  <div class="card">
    <div class="card-header flex justify-between items-center">
      <h2 class="text-lg font-medium">Students</h2>
      
      <a href="<%= students_course_path(@course) %>" class="text-sm text-white hover:underline">
        View All
      </a>
    </div>
    
    <div class="card-body">
      <% if @students.any? %>
        <div class="flow-root">
          <ul class="divide-y divide-gray-200">
            <% @students.first(5).each do |student| %>
              <li class="py-3">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                      <%= student.first_name.first.upcase %><%= student.last_name&.first&.upcase || '' %>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= student.full_name %>
                    </p>
                    <% if student.student_number.present? %>
                      <p class="text-xs text-gray-500 truncate">
                        ID: <%= student.student_number %>
                      </p>
                    <% end %>
                  </div>
                  
                  <% avg_grade = student.average_grade %>
                  <% if avg_grade > 0 %>
                    <% letter = @course.teacher.default_grade_scale.letter_for_percent(avg_grade) %>
                    <% bg_color = case letter
                                  when 'A' then 'bg-green-100 text-green-800'
                                  when 'B' then 'bg-blue-100 text-blue-800'
                                  when 'C' then 'bg-yellow-100 text-yellow-800'
                                  when 'D' then 'bg-orange-100 text-orange-800'
                                  when 'F' then 'bg-red-100 text-red-800'
                                  end %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= bg_color %>">
                      <%= avg_grade.round %>% (<%= letter %>)
                    </span>
                  <% else %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                      No grades
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
        
        <div class="mt-4">
          <a href="<%= students_course_path(@course) %>" class="btn btn-primary w-full">
            <i data-lucide="users" class="w-4 h-4 mr-1"></i> Manage Students
          </a>
        </div>
      <% else %>
        <div class="text-center py-6">
          <div class="text-gray-400 mb-3">
            <i data-lucide="users" class="h-12 w-12 mx-auto"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No students enrolled</h3>
          <p class="text-gray-500 mb-4">Add students to this class to get started</p>
          
          <a href="<%= students_course_path(@course) %>" class="btn btn-primary">
            <i data-lucide="user-plus" class="w-4 h-4 mr-1"></i> Add Students
          </a>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Assignments Card -->
  <div class="card">
    <div class="card-header flex justify-between items-center">
      <h2 class="text-lg font-medium">Assignments</h2>
      
      <a href="<%= assignments_course_path(@course) %>" class="text-sm text-white hover:underline">
        View All
      </a>
    </div>
    
    <div class="card-body">
      <% if @assignments.any? %>
        <div class="flow-root">
          <ul class="divide-y divide-gray-200">
            <% @assignments.each do |assignment| %>
              <li class="py-3">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                      <i data-lucide="file-text" class="h-4 w-4"></i>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= assignment.name %>
                    </p>
                    <p class="text-xs text-gray-500 truncate">
                      <% if assignment.due_date %>
                        <% if assignment.due_date > Time.current %>
                          <span class="text-blue-600">Due <%= time_ago_in_words(assignment.due_date) %> from now</span>
                        <% else %>
                          <span class="text-gray-500">Due <%= time_ago_in_words(assignment.due_date) %> ago</span>
                        <% end %>
                      <% end %>
                      
                      <% if assignment.max_score %>
                        <span class="mx-1">•</span>
                        <span><%= assignment.max_score %> points</span>
                      <% end %>
                    </p>
                  </div>
                  
                  <div class="text-right text-xs">
                    <div class="font-medium"><%= assignment.graded_count %>/<%= @course.students.count %></div>
                    <div class="text-gray-500">graded</div>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
        
        <div class="mt-4">
          <a href="<%= new_assignment_path(class_id: @course.id) %>" class="btn btn-primary w-full">
            <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Add Assignment
          </a>
        </div>
      <% else %>
        <div class="text-center py-6">
          <div class="text-gray-400 mb-3">
            <i data-lucide="file-text" class="h-12 w-12 mx-auto"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No assignments yet</h3>
          <p class="text-gray-500 mb-4">Create assignments to track student progress</p>
          
          <a href="<%= new_assignment_path(class_id: @course.id) %>" class="btn btn-primary">
            <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Add Assignment
          </a>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Recent Activity -->
  <div class="card">
    <div class="card-header">
      <h2 class="text-lg font-medium">Recent Activity</h2>
    </div>
    
    <div class="card-body">
      <% if @recent_grades.any? %>
        <div class="flow-root">
          <ul class="divide-y divide-gray-200">
            <% @recent_grades.each do |grade| %>
              <li class="py-3">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                      <%= grade.student.first_name.first.upcase %><%= grade.student.last_name&.first&.upcase || '' %>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= grade.student.full_name %> - <%= grade.assignment.name %>
                    </p>
                    <p class="text-xs text-gray-500 truncate">
                      <%= time_ago_in_words(grade.created_at) %> ago
                    </p>
                  </div>
                  <div class="flex-shrink-0 text-sm font-medium">
                    <% bg_color = case grade.letter_grade
                                  when 'A' then 'bg-green-100 text-green-800'
                                  when 'B' then 'bg-blue-100 text-blue-800'
                                  when 'C' then 'bg-yellow-100 text-yellow-800'
                                  when 'D' then 'bg-orange-100 text-orange-800'
                                  when 'F' then 'bg-red-100 text-red-800'
                                  end %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= bg_color %>">
                      <%= grade.score %>% (<%= grade.letter_grade %>)
                    </span>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-6">
          <div class="text-gray-400 mb-3">
            <i data-lucide="activity" class="h-12 w-12 mx-auto"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">No recent activity</h3>
          <p class="text-gray-500">Grade assignments to see activity here</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Grade Distribution -->
<div class="card mt-6">
  <div class="card-header">
    <h2 class="text-lg font-medium">Grade Distribution</h2>
  </div>
  <div class="card-body">
    <% if @grade_distribution.any? %>
      <% 
        # Define the order for letter grades
        grade_order = ['A', 'B', 'C', 'D', 'F']
        
        # Define colors for each grade
        colors = {
          'A' => 'bg-green-500',
          'B' => 'bg-blue-500',
          'C' => 'bg-yellow-500',
          'D' => 'bg-orange-500',
          'F' => 'bg-red-500'
        }
        
        # Calculate total for percentages
        total = @grade_distribution.values.sum
        
        # Sort by the defined order
        sorted_distribution = grade_order.map do |grade|
          [grade, @grade_distribution[grade] || 0]
        end
      %>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="space-y-4">
            <% sorted_distribution.each do |grade, count| %>
              <% next if count == 0 %>
              <% percentage = total > 0 ? (count.to_f / total * 100).round : 0 %>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <div class="text-sm font-medium text-gray-700"><%= grade %></div>
                  <div class="text-sm text-gray-500"><%= count %> (<%= percentage %>%)</div>
                </div>
                <div class="progress">
                  <div class="progress-bar <%= colors[grade] %>" style="width: <%= percentage %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        
        <div class="flex items-center justify-center">
          <!-- This would be a chart in a real app -->
          <div class="flex space-x-2 h-40">
            <% sorted_distribution.each do |grade, count| %>
              <% next if count == 0 %>
              <% percentage = total > 0 ? (count.to_f / total * 100).round : 0 %>
              <div class="flex flex-col items-center">
                <div class="flex-1 w-12 flex items-end">
                  <div class="<%= colors[grade] %> w-full rounded-t-md" style="height: <%= percentage %>%;"></div>
                </div>
                <div class="text-sm font-medium mt-2"><%= grade %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-6">
        <div class="text-gray-400 mb-3">
          <i data-lucide="bar-chart-2" class="h-12 w-12 mx-auto"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-1">No grades yet</h3>
        <p class="text-gray-500">Start grading assignments to see distribution here</p>
      </div>
    <% end %>
  </div>
</div>