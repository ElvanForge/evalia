<% content_for :page_title do %>
  Dashboard
<% end %>

<!-- Welcome Card -->
<div class="bg-white rounded-lg shadow-sm overflow-hidden mb-6">
  <div class="bg-gradient-to-r from-primary to-primary/80 text-white p-6">
    <h1 class="text-2xl font-bold">Welcome back, <%= current_user.first_name %>!</h1>
    <p class="mt-2 opacity-90">Here's what's happening across your classes today.</p>
  </div>
  <div class="px-6 py-4 bg-gradient-to-r from-primary/10 to-primary/5 flex items-center justify-between">
    <div class="flex space-x-6">
      <div>
        <p class="text-sm text-gray-500 font-medium">Classes</p>
        <p class="text-xl font-bold"><%= current_user.courses.active.count %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500 font-medium">Students</p>
        <p class="text-xl font-bold"><%= @total_students %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500 font-medium">Assignments</p>
        <p class="text-xl font-bold"><%= @total_assignments %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500 font-medium">Grading Completion</p>
        <p class="text-xl font-bold"><%= @grading_completion %>%</p>
      </div>
    </div>
    
    <div>
      <a href="<%= new_course_path %>" class="btn btn-primary">
        <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
        Add Class
      </a>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
  <!-- Classes Card -->
  <div class="md:col-span-2">
    <div class="card">
      <div class="card-header flex justify-between items-center">
        <h2 class="text-lg font-medium">Your Classes</h2>
        
        <a href="<%= courses_path %>" class="text-sm text-white hover:underline">
          View All
        </a>
      </div>
      
      <div class="card-body">
        <% if @courses.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% @courses.each do |course| %>
              <a href="<%= course_path(course) %>" class="block p-4 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors">
                <h3 class="font-semibold text-gray-900"><%= course.name %></h3>
                
                <div class="mt-2 flex items-center text-xs text-gray-500">
                  <% if course.subject.present? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                      <%= course.subject %>
                    </span>
                  <% end %>
                  
                  <% if course.grade_level.present? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      Grade <%= course.grade_level %>
                    </span>
                  <% end %>
                </div>
                
                <div class="mt-3 flex items-center justify-between text-sm">
                  <div class="flex items-center text-gray-500">
                    <i data-lucide="users" class="h-4 w-4 mr-1"></i>
                    <%= course.students.count %> Students
                  </div>
                  
                  <div class="flex items-center text-gray-500">
                    <i data-lucide="file-text" class="h-4 w-4 mr-1"></i>
                    <%= course.assignments.count %> Assignments
                  </div>
                </div>
              </a>
            <% end %>
          </div>
          
          <% if current_user.courses.active.count > 6 %>
            <div class="mt-4 text-center">
              <a href="<%= courses_path %>" class="btn btn-outline">
                View All Classes
              </a>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-8">
            <div class="text-gray-400 mb-4">
              <i data-lucide="book-open" class="h-12 w-12 mx-auto"></i>
            </div>
            
            <h3 class="text-lg font-medium text-gray-900 mb-2">No Classes Yet</h3>
            <p class="text-gray-500 mb-6">Start adding classes to organize your students and assignments</p>
            
            <a href="<%= new_course_path %>" class="btn btn-primary">
              <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
              Add Class
            </a>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Quick Tools -->
  <div>
    <div class="card mb-6">
      <div class="card-header">
        <h2 class="text-lg font-medium">Quick Tools</h2>
      </div>
      
      <div class="card-body">
        <div class="grid grid-cols-1 gap-4">
          <a href="<%= new_assignment_path %>" class="block p-4 rounded-lg bg-blue-50 hover:bg-blue-100 transition-colors">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                <i data-lucide="file-plus" class="h-5 w-5"></i>
              </div>
              <div class="ml-3">
                <h3 class="font-medium text-gray-900">Create Assignment</h3>
                <p class="text-sm text-gray-500">Add a new assignment to any class</p>
              </div>
            </div>
          </a>
          
          <a href="<%= new_quiz_path %>" class="block p-4 rounded-lg bg-purple-50 hover:bg-purple-100 transition-colors">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600">
                <i data-lucide="check-square" class="h-5 w-5"></i>
              </div>
              <div class="ml-3">
                <h3 class="font-medium text-gray-900">Create Quiz</h3>
                <p class="text-sm text-gray-500">Build an interactive assessment</p>
              </div>
            </div>
          </a>
          
          <a href="<%= reports_path %>" class="block p-4 rounded-lg bg-green-50 hover:bg-green-100 transition-colors">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                <i data-lucide="trending-up" class="h-5 w-5"></i>
              </div>
              <div class="ml-3">
                <h3 class="font-medium text-gray-900">Reports</h3>
                <p class="text-sm text-gray-500">View analytics and export data</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
    
    <!-- At-Risk Students -->
    <div class="card">
      <div class="card-header flex justify-between items-center">
        <h2 class="text-lg font-medium">Student Alerts</h2>
      </div>
      
      <div class="card-body">
        <% if @at_risk_students.any? %>
          <div class="flow-root">
            <ul class="divide-y divide-gray-200">
              <% @at_risk_students.each do |student| %>
                <li class="py-3">
                  <div class="flex items-center space-x-4">
                    <div class="flex-shrink-0">
                      <div class="h-8 w-8 rounded-full bg-red-100 flex items-center justify-center text-red-600">
                        <i data-lucide="alert-circle" class="h-4 w-4"></i>
                      </div>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= student.full_name %>
                      </p>
                      <p class="text-xs text-gray-500 truncate">
                        At risk in <%= pluralize(student.courses.count, 'class') %>
                      </p>
                    </div>
                    <div>
                      <a href="#" class="inline-flex items-center rounded-full border border-gray-300 bg-white px-2.5 py-0.5 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                        View
                      </a>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="text-gray-400 mb-3">
              <i data-lucide="check-circle" class="h-12 w-12 mx-auto"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-1">No At-Risk Students</h3>
            <p class="text-gray-500">All your students are performing well</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 mt-6 md:grid-cols-2">
  <!-- Recent Activity -->
  <div class="card">
    <div class="card-header">
      <h2 class="text-lg font-medium">Recent Activity</h2>
    </div>
    
    <div class="card-body">
      <% if @recent_grades.any? %>
        <div class="flow-root">
          <ul class="divide-y divide-gray-200">
            <% @recent_grades.each do |grade| %>
              <li class="py-3">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                      <%= grade.student.first_name.first.upcase %><%= grade.student.last_name&.first&.upcase || '' %>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= grade.student.full_name %> - <%= grade.assignment.name %>
                    </p>
                    <p class="text-xs text-gray-500 truncate">
                      <%= grade.assignment.course.name %> | <%= time_ago_in_words(grade.created_at) %> ago
                    </p>
                  </div>
                  <div>
                    <%= grade_badge(grade.letter_grade) %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-8">
          <div class="text-gray-400 mb-4">
            <i data-lucide="activity" class="h-12 w-12 mx-auto"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No Recent Activity</h3>
          <p class="text-gray-500">Activity will appear here once you start grading</p>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Upcoming Assignments -->
  <div class="card">
    <div class="card-header">
      <h2 class="text-lg font-medium">Upcoming Due Dates</h2>
    </div>
    
    <div class="card-body">
      <% if @upcoming_assignments.any? %>
        <div class="flow-root">
          <ul class="divide-y divide-gray-200">
            <% @upcoming_assignments.each do |assignment| %>
              <li class="py-3">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                      <i data-lucide="calendar" class="h-4 w-4"></i>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= assignment.name %>
                    </p>
                    <p class="text-xs text-gray-500 truncate">
                      <%= assignment.course.name %> | Due in <%= distance_of_time_in_words(Time.current, assignment.due_date) %>
                    </p>
                  </div>
                  <div>
                    <% completion = assignment.graded_count.to_f / assignment.course.students.count * 100 %>
                    <% completion = completion.round %>
                    <div class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs">
                      <div class="inline-block h-2 w-16 rounded-full overflow-hidden bg-gray-200">
                        <div class="h-full bg-blue-500" style="width: <%= completion %>%"></div>
                      </div>
                      <span class="ml-1.5 text-gray-700"><%= completion %>%</span>
                    </div>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-8">
          <div class="text-gray-400 mb-4">
            <i data-lucide="calendar" class="h-12 w-12 mx-auto"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No Upcoming Deadlines</h3>
          <p class="text-gray-500">You're all caught up! Add new assignments to see deadlines</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Grade Distribution -->
<div class="card mt-6">
  <div class="card-header">
    <h2 class="text-lg font-medium">Grade Distribution</h2>
  </div>
  <div class="card-body">
    <% if @grade_distribution.values.sum > 0 %>
      <% 
        # Define the order for letter grades
        grade_order = ['A', 'B', 'C', 'D', 'F']
        
        # Define colors for each grade
        colors = {
          'A' => 'bg-green-500',
          'B' => 'bg-blue-500',
          'C' => 'bg-yellow-500',
          'D' => 'bg-orange-500',
          'F' => 'bg-red-500'
        }
        
        # Calculate total for percentages
        total = @grade_distribution.values.sum
        
        # Sort by the defined order
        sorted_distribution = grade_order.map do |grade|
          [grade, @grade_distribution[grade] || 0]
        end
      %>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="space-y-4">
            <% sorted_distribution.each do |grade, count| %>
              <% next if count == 0 %>
              <% percentage = total > 0 ? (count.to_f / total * 100).round : 0 %>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <div class="text-sm font-medium text-gray-700"><%= grade %></div>
                  <div class="text-sm text-gray-500"><%= count %> (<%= percentage %>%)</div>
                </div>
                <div class="h-2 w-full bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full <%= colors[grade] %>" style="width: <%= percentage %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        
        <div class="flex items-center justify-center">
          <!-- Simple bar chart -->
          <div class="flex space-x-2 h-40">
            <% sorted_distribution.each do |grade, count| %>
              <% next if count == 0 %>
              <% percentage = total > 0 ? (count.to_f / total * 100).round : 0 %>
              <div class="flex flex-col items-center">
                <div class="flex-1 w-12 flex items-end">
                  <div class="<%= colors[grade] %> w-full rounded-t-md" style="height: <%= percentage %>%;"></div>
                </div>
                <div class="text-sm font-medium mt-2"><%= grade %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="text-gray-400 mb-4">
          <i data-lucide="bar-chart-2" class="h-12 w-12 mx-auto"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No Grades Yet</h3>
        <p class="text-gray-500">Start grading assignments to see grade distribution</p>
      </div>
    <% end %>
  </div>
</div>