<% content_for :page_title do %>
  Dashboard
<% end %>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <!-- Welcome Card -->
  <div class="lg:col-span-3">
    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-medium">Welcome back, <%= current_user&.first_name || 'Teacher' %>!</h2>
      </div>
      <div class="card-body bg-gradient-to-r from-primary to-primary-light text-white">
        <p class="mb-2">This is your teacher dashboard. Get a quick overview of your classes, recent activities, and items that need attention.</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href="<%= courses_path if defined?(courses_path) %>" class="inline-flex items-center px-3 py-1 bg-white text-primary rounded-md text-sm font-medium shadow-sm hover:bg-gray-100">
            <i data-lucide="book-open" class="w-4 h-4 mr-1"></i> Classes
          </a>
          <a href="<%= students_path if defined?(students_path) %>" class="inline-flex items-center px-3 py-1 bg-white text-primary rounded-md text-sm font-medium shadow-sm hover:bg-gray-100">
            <i data-lucide="users" class="w-4 h-4 mr-1"></i> Students
          </a>
          <a href="<%= assignments_path if defined?(assignments_path) %>" class="inline-flex items-center px-3 py-1 bg-white text-primary rounded-md text-sm font-medium shadow-sm hover:bg-gray-100">
            <i data-lucide="clipboard-list" class="w-4 h-4 mr-1"></i> Assignments
          </a>
          <a href="<%= quizzes_path if defined?(quizzes_path) %>" class="inline-flex items-center px-3 py-1 bg-white text-primary rounded-md text-sm font-medium shadow-sm hover:bg-gray-100">
            <i data-lucide="check-square" class="w-4 h-4 mr-1"></i> Quizzes
          </a>
          <a href="<%= reports_path if defined?(reports_path) %>" class="inline-flex items-center px-3 py-1 bg-white text-primary rounded-md text-sm font-medium shadow-sm hover:bg-gray-100">
            <i data-lucide="bar-chart-2" class="w-4 h-4 mr-1"></i> Reports
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Classes Card -->
  <div class="lg:col-span-2">
    <div class="card h-full">
      <div class="card-header flex justify-between items-center">
        <h2 class="text-lg font-medium">Your Classes</h2>
        <a href="<%= new_course_path if defined?(new_course_path) %>" class="inline-flex items-center text-sm text-white hover:underline">
          <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Add Class
        </a>
      </div>
      <div class="card-body">
        <% if @courses&.any? %>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <% @courses.each do |course| %>
              <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                <h3 class="text-lg font-medium text-gray-900"><%= course.name %></h3>
                <p class="text-sm text-gray-500 mb-2">
                  <%= course.student_count %> students
                </p>
                <div class="mt-3 flex gap-2">
                  <a href="<%= course_path(course) if defined?(course_path) %>" class="text-xs px-2 py-1 bg-primary text-white rounded hover:bg-primary-dark">
                    View Class
                  </a>
                  <a href="<%= course_students_path(course) if defined?(course_students_path) %>" class="text-xs px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200">
                    Students
                  </a>
                  <a href="<%= course_assignments_path(course) if defined?(course_assignments_path) %>" class="text-xs px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200">
                    Assignments
                  </a>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="text-gray-400 mb-3">
              <i data-lucide="book-open" class="w-12 h-12 mx-auto"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-1">No classes yet</h3>
            <p class="text-gray-500 mb-4">Get started by creating your first class</p>
            <a href="<%= new_course_path if defined?(new_course_path) %>" class="btn btn-primary">
              <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Add Class
            </a>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Quick Tools Section -->
  <div class="lg:col-span-1">
    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-medium">Quick Tools</h2>
      </div>
      <div class="card-body">
        <div class="space-y-4">
          <div class="bg-gray-50 p-3 rounded-md border border-gray-200">
            <h3 class="font-medium text-gray-900 flex items-center">
              <i data-lucide="clipboard-list" class="w-4 h-4 mr-2 text-primary"></i>
              <span>View Assignments</span>
            </h3>
            <p class="text-xs text-gray-500 mb-2">View and manage all assignment records</p>
            <a href="<%= assignments_path if defined?(assignments_path) %>" class="text-xs px-2 py-1 bg-primary text-white rounded hover:bg-primary-dark inline-block">
              Go to Assignments
            </a>
          </div>
          
          <div class="bg-gray-50 p-3 rounded-md border border-gray-200">
            <h3 class="font-medium text-gray-900 flex items-center">
              <i data-lucide="plus-circle" class="w-4 h-4 mr-2 text-success"></i>
              <span>Create Assignment</span>
            </h3>
            <p class="text-xs text-gray-500 mb-2">Add a new assignment to any class</p>
            <a href="<%= new_assignment_path if defined?(new_assignment_path) %>" class="text-xs px-2 py-1 bg-success text-white rounded hover:bg-green-600 inline-block">
              New Assignment
            </a>
          </div>
          
          <div class="bg-gray-50 p-3 rounded-md border border-gray-200">
            <h3 class="font-medium text-gray-900 flex items-center">
              <i data-lucide="alert-circle" class="w-4 h-4 mr-2 text-warning"></i>
              <span>Student Alerts</span>
            </h3>
            <p class="text-xs text-gray-500 mb-2">Students who need attention</p>
            <a href="<%= student_alerts_path if defined?(student_alerts_path) %>" class="text-xs px-2 py-1 bg-warning text-white rounded hover:bg-yellow-600 inline-block">
              View Alerts (<%= @student_alerts&.count || 0 %>)
            </a>
          </div>
          
          <div class="bg-gray-50 p-3 rounded-md border border-gray-200">
            <h3 class="font-medium text-gray-900 flex items-center">
              <i data-lucide="edit-3" class="w-4 h-4 mr-2 text-primary"></i>
              <span>Quick Grade Entry</span>
            </h3>
            <p class="text-xs text-gray-500 mb-2">Enter grades for recent assignments</p>
            <a href="<%= quick_grade_path if defined?(quick_grade_path) %>" class="text-xs px-2 py-1 bg-primary text-white rounded hover:bg-primary-dark inline-block">
              Enter Grades
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Recent Activity Card -->
  <div class="lg:col-span-2">
    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-medium">Recent Activity</h2>
      </div>
      <div class="card-body">
        <% if @recent_grades&.any? %>
          <div class="flow-root">
            <ul class="divide-y divide-gray-200">
              <% @recent_grades.each do |grade| %>
                <li class="py-3">
                  <div class="flex items-center space-x-4">
                    <div class="flex-shrink-0">
                      <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                        <%= grade.student.first_name&.first&.upcase || 'S' %>
                      </div>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-gray-900 truncate">
                        <%= "#{grade.first_name} #{grade.last_name}" %>
                      </p>
                      <p class="text-sm text-gray-500">
                        <%= grade.assignment_name %>
                      </p>
                    </div>
                    <div>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                        <%= grade.score >= 90 ? 'bg-green-100 text-green-800' : 
                          (grade.score >= 80 ? 'bg-blue-100 text-blue-800' : 
                          (grade.score >= 70 ? 'bg-yellow-100 text-yellow-800' : 
                          'bg-red-100 text-red-800')) %>"
                      >
                        <%= grade.score %>% (<%= grade.letter_grade %>)
                      </span>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="text-gray-400 mb-3">
              <i data-lucide="activity" class="w-12 h-12 mx-auto"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-1">No recent activity</h3>
            <p class="text-gray-500">Activity will appear here when you start grading assignments</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Grade Distribution Card -->
  <div class="lg:col-span-1">
    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-medium">Grade Distribution</h2>
      </div>
      <div class="card-body">
        <% if @grade_distribution&.any? %>
          <div class="space-y-4">
            <% 
              # Define the order for letter grades
              grade_order = ['A', 'B', 'C', 'D', 'F']
              
              # Define colors for each grade
              colors = {
                'A' => 'bg-green-500',
                'B' => 'bg-blue-500',
                'C' => 'bg-yellow-500',
                'D' => 'bg-orange-500',
                'F' => 'bg-red-500'
              }
              
              # Calculate total for percentages
              total = @grade_distribution.values.sum
              
              # Sort by the defined order
              sorted_distribution = grade_order.map do |grade|
                [grade, @grade_distribution[grade] || 0]
              end
            %>
            
            <% sorted_distribution.each do |grade, count| %>
              <% next if count == 0 %>
              <% percentage = total > 0 ? (count.to_f / total * 100).round : 0 %>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <div class="text-sm font-medium text-gray-700"><%= grade %></div>
                  <div class="text-sm text-gray-500"><%= count %> (<%= percentage %>%)</div>
                </div>
                <div class="progress">
                  <div class="progress-bar <%= colors[grade] %>" style="width: <%= percentage %>%"></div>
                </div>
              </div>
            <% end %>
            
            <div class="mt-4 text-center">
              <a href="<%= reports_path if defined?(reports_path) %>" class="text-sm text-primary hover:underline">
                View detailed reports
              </a>
            </div>
          </div>
        <% else %>
          <div class="text-center py-6">
            <div class="text-gray-400 mb-3">
              <i data-lucide="bar-chart-2" class="w-12 h-12 mx-auto"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-1">No grades yet</h3>
            <p class="text-gray-500">Grade distribution will appear here when you start grading assignments</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>