<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <!-- Welcome card -->
  <div class="col-span-full bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white p-6">
      <h2 class="text-2xl font-bold">Welcome back, <%= current_teacher.first_name %></h2>
      <p class="mt-1 text-white/80">Here's what's happening today</p>
    </div>
    <div class="p-6">
      <p>You have <%= @upcoming_assignments.count %> assignments due soon.</p>
    </div>
  </div>
  
  <!-- Classes card -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white px-4 py-3 flex justify-between items-center">
      <h3 class="font-bold">Your Classes</h3>
      <%= link_to new_course_path, class: "bg-white text-primary text-sm px-2 py-1 rounded" do %>
        <span class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
          Add
        </span>
      <% end %>
    </div>
    <div class="p-4">
      <% if @classes.any? %>
        <div class="space-y-2">
          <% @classes.each do |course| %>
            <div class="p-3 border rounded-md hover:bg-background transition-colors">
              <div class="flex justify-between items-center">
                <h4 class="font-semibold"><%= link_to course.name, course_path(course) %></h4>
                <span class="text-sm text-gray-500"><%= pluralize(course.students.count, 'student') %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-4">
          <p class="text-gray-500 mb-2">No classes yet</p>
          <%= link_to "Create Class", new_course_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Quick Tools -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white px-4 py-3">
      <h3 class="font-bold">Quick Tools</h3>
    </div>
    <div class="p-4">
      <div class="grid grid-cols-2 gap-4">
        <!-- Create Assignment -->
        <%= link_to new_assignment_path, class: "flex flex-col items-center p-4 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-2" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">Create Assignment</span>
        <% end %>
        
        <!-- Grade Entry -->
        <%= link_to quick_grades_path, class: "flex flex-col items-center p-4 rounded-lg bg-emerald-100 text-emerald-700 hover:bg-emerald-200 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-2" viewBox="0 0 20 20" fill="currentColor">
            <path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z" />
            <path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">Grade Entry</span>
        <% end %>
        
        <!-- Student Alerts -->
        <%= link_to alerts_path, class: "flex flex-col items-center p-4 rounded-lg bg-amber-100 text-amber-700 hover:bg-amber-200 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">Student Alerts</span>
        <% end %>
        
        <!-- Create Quiz -->
        <%= link_to new_quiz_path, class: "flex flex-col items-center p-4 rounded-lg bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">Create Quiz</span>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Recent Activity -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white px-4 py-3">
      <h3 class="font-bold">Recent Activity</h3>
    </div>
    <div class="p-4">
      <% if @recent_grades.any? %>
        <ul class="divide-y">
          <% @recent_grades.each do |grade| %>
            <li class="py-3">
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                    <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm">
                    <span class="font-medium">
                      <%= grade.student ? "#{grade.student.first_name} #{grade.student.last_name}" : "Unknown Student" %>
                    </span> 
                    received <%= grade.score %>% on 
                    <span class="font-medium"><%= grade.assignment.name %></span>
                  </p>
                  <p class="text-xs text-gray-500"><%= time_ago_in_words(grade.created_at) %> ago</p>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-center py-4 text-gray-500">No recent activity</p>
      <% end %>
    </div>
  </div>
  
  <!-- Student Alerts -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white px-4 py-3 flex justify-between items-center">
      <h3 class="font-bold">Student Alerts</h3>
      <%= link_to alerts_path, class: "text-white text-sm hover:underline" do %>
        View all
      <% end %>
    </div>
    <div class="p-4">
      <% if @student_alerts.any? %>
        <ul class="divide-y">
          <% @student_alerts.each do |alert| %>
            <li class="py-3">
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm">
                    <span class="font-medium"><%= alert[:name] %></span>: 
                    <%= alert[:message] %>
                  </p>
                  <p class="text-xs text-gray-500"><%= time_ago_in_words(alert[:created_at]) %> ago</p>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-center py-4 text-gray-500">No alerts at this time</p>
      <% end %>
    </div>
  </div>
  
  <!-- Grade Distribution -->
  <div class="col-span-full bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-primary text-white px-4 py-3">
      <h3 class="font-bold">Grade Distribution</h3>
    </div>
    <div class="p-6">
      <div class="h-64 flex items-center justify-center">
        <%= content_tag :div, "", 
          id: "grade-chart", 
          data: { 
            controller: "chart",
            chart_type: "bar",
            chart_data: {
              labels: ["A", "B", "C", "D", "F"],
              datasets: [{
                label: "Students",
                backgroundColor: "#0ba2b0",
                data: [12, 15, 8, 5, 2]
              }]
            }.to_json
          }, 
          class: "w-full h-full" 
        %>
      </div>
    </div>
  </div>
</div>